<Application x:Class="OzonPriceCalculator.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <!-- 全局资源 -->
        <SolidColorBrush x:Key="MacWhiteBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="MacGrayBrush" Color="#F5F5F7"/>
        <SolidColorBrush x:Key="MacDarkGrayBrush" Color="#86868B"/>
        <SolidColorBrush x:Key="MacBlackBrush" Color="#1D1D1F"/>
        <SolidColorBrush x:Key="MacBlueBrush" Color="#0071E3"/>
        
        <!-- 圆角半径 -->
        <CornerRadius x:Key="MacCornerRadius">18</CornerRadius>
        <CornerRadius x:Key="MacLargeCornerRadius">24</CornerRadius>
        
        <!-- 字体 -->
        <FontFamily x:Key="MacFont">Segoe UI, Inter</FontFamily>
        
    </Application.Resources>
</Application>
